# Contact / "Book a demo" lead delivery (Resend). Optional in dev:
# when RESEND_API_KEY is unset the contact action logs and no-ops gracefully.
RESEND_API_KEY=

# Verified Resend sender. Defaults to "Ops Wizard <onboarding@resend.dev>" when unset.
RESEND_FROM=

# Where booking/demo leads are emailed. Defaults to the address below.
LEADS_TO=sebastien.germain1989@gmail.com

# Absolute site origin used in <head> canonical / OG tags.
PUBLIC_SITE_URL=https://wizardops.ca
